<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/feedFragment4">
    <fragment
        android:id="@+id/feedFragment4"
        android:name="ru.netology.nmedia.fragment.FeedFragment"
        android:label="FeedFragment"
        tools:layout="@layout/fragment_feed">
        <action
            android:id="@+id/action_feedFragment4_to_newPostFragment2"
            app:destination="@id/newPostFragment2"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out"
            app:popEnterAnim="@android:anim/fade_in"
            app:popExitAnim="@android:anim/fade_out" />

        <action
            android:id="@+id/action_feedFragment4_to_cardPostFragment"
            app:destination="@id/cardPostFragment" />
    </fragment>
    <fragment
        android:id="@+id/newPostFragment2"
        android:name="ru.netology.nmedia.fragment.NewPostFragment"
        android:label="NewPostFragment"
        tools:layout="@layout/fragment_new_post" />
    <fragment
        android:id="@+id/cardPostFragment"
        android:name="ru.netology.nmedia.fragment.CardPostFragment"
        android:label="CardPostFragment"
        tools:layout="@layout/fragment_card_post">
        <action
            android:id="@+id/action_cardPostFragment_to_newPostFragment2"
            app:destination="@id/newPostFragment2" />
    </fragment>
</navigation>